{
  "manifest_version": 3,
  "name": "NEXUS New Tab",
  "version": "1.1.0",
  "description": "Opens NEXUS at lightning speed when you open a new tab",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["alarms"],
  "host_permissions": ["https://nexus.lj-buchmiller.com/*"]
}

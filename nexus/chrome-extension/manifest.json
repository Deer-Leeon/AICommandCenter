{
  "manifest_version": 3,
  "name": "NEXUS New Tab",
  "version": "1.1.0",
  "description": "Turn every new tab into your command center — live sports, stocks, AI assistant, calendar, tasks, and Spotify. All in one place.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["alarms"],
  "host_permissions": ["https://nexus.lj-buchmiller.com/*"]
}

{
  "name": "nexus-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:ext": "tsc --noEmit && vite build --config vite.extension.config.ts",
    "build:extension": "tsc --noEmit && vite build --config vite.extension.config.ts && node scripts/clean-extension-build.js",
    "preview": "vite preview",
    "build:ios": "tsc && vite build && npx cap sync ios",
    "open:ios": "npx cap open ios",
    "ios:dev": "tsc && vite build && npx cap sync ios && npx cap open ios",
    "cap:sync": "npx cap sync",
    "cap:init": "npx cap init NEXUS com.nexus.app --web-dir dist",
    "cap:add:ios": "npx cap add ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.98.0",
    "chess.js": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plaid-link": "^4.1.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@types/chrome": "^0.1.37",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.2.2",
    "vite": "^5.4.21"
  }
}

FROM node:22-alpine

WORKDIR /app

# Copy root package files
COPY package*.json ./

# Copy backend package files and install dependencies
COPY backend/package*.json ./backend/
WORKDIR /app/backend
RUN npm install

# Copy backend source code
WORKDIR /app
COPY backend/ ./backend/

# Copy tokens.json if it exists
COPY tokens.json* ./

# Compile TypeScript
WORKDIR /app/backend
RUN npx tsc

EXPOSE 3001

CMD ["node", "dist/index.js"]

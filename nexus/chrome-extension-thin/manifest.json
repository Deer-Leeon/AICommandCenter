{
  "manifest_version": 3,
  "name": "NEXUS",
  "version": "2.0.0",
  "description": "Replace your new tab with NEXUS — a personal productivity dashboard with widgets for calendar, weather, stocks, music, and more.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "search"
  ],
  "externally_connectable": {
    "matches": ["https://nexus.lj-buchmiller.com/*"]
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}

# ─────────────────────────────────────────────
# NEXUS — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# SERVER
PORT=
NODE_ENV=
FRONTEND_URL=
PRODUCTION_URL=

# ─── OLLAMA ───────────────────────────────────
# Make sure Ollama is running: `ollama serve`
# Pull your model first: `ollama pull llama3`
OLLAMA_BASE_URL=
OLLAMA_MODEL=
# Options: llama3, mistral, mixtral, llama3:70b, etc.

# ─── GOOGLE (Calendar + Docs) ─────────────────
# 1. Go to console.cloud.google.com
# 2. Create project → Enable Google Calendar API + Google Docs API
# 3. Credentials → Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URI: http://localhost:3001/api/auth/google/callback
# 5. Copy Client ID and Secret below
# 6. Visit http://localhost:3001/api/auth/google to complete OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# ─── SLACK ────────────────────────────────────
# Bot token (fallback if user hasn't connected their own Slack account)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=
#
# Per-user Slack OAuth — add these to enable "Connect Slack" for each user:
# 1. Go to api.slack.com/apps → select your NEXUS app
# 2. OAuth & Permissions → Redirect URLs → Add:
#    https://nexus-api.lj-buchmiller.com/api/auth/slack/callback
# 3. OAuth & Permissions → User Token Scopes → Add:
#    channels:history, channels:read, groups:history, groups:read,
#    im:history, im:read, im:write, mpim:read, mpim:history,
#    chat:write, users:read
# 4. Basic Information → App Credentials → copy Client ID and Client Secret below
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=

# ─── OBSIDIAN ─────────────────────────────────
# Requires "Local REST API" community plugin in Obsidian
# Plugin settings: enable, set API key, note port (default 27123)
OBSIDIAN_API_URL=
OBSIDIAN_API_KEY=
OBSIDIAN_VAULT_NAME=
OBSIDIAN_GROCERY_FILE=
OBSIDIAN_NOTES_FOLDER=

# ─── PLAID (financial data) ───────────────────
# 1. Go to dashboard.plaid.com → create an app
# 2. Copy Client ID from Team Settings → Keys
# 3. Copy Sandbox (or Production) Secret from the same page
# 4. Set PLAID_ENV to 'sandbox' for testing or 'production' for live data
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=

# ─── WEATHER (optional) ───────────────────────
# Free key from openweathermap.org
OPENWEATHER_API_KEY=
OPENWEATHER_DEFAULT_CITY=

# ─── TIMEZONE ─────────────────────────────────
# Used to calculate correct local dates for AI responses
# Find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
USER_TIMEZONE=

# ─── SESSION ──────────────────────────────────
SESSION_SECRET=

# ─── CLOUDFLARE TUNNEL ────────────────────────
# Get this from: cloudflare.com → Zero Trust → Tunnels → nexus → Configure → Token
CLOUDFLARE_TUNNEL_TOKEN=

# ─── SUPABASE ─────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── FOOTBALL (Football widget) ──────────────────────────────────
# football-data.org: free, current season, 10 req/min, 12 major competitions
# Register free at: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=

# ─── FINNHUB (Stocks widget) ───────────────────────────────
# Free API key at: https://finnhub.io (sign up → Dashboard → API Key)
FINNHUB_API_KEY=

# ─── SPOTIFY ─────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=
# Shared .dockerignore for both Dockerfile.backend and Dockerfile.frontend.
# Excludes heavy/generated artifacts that neither service needs,
# but keeps frontend source files so Dockerfile.frontend can build them.

# ── Never needed by either service ──────────────────────────────────────────

# Node modules (reinstalled inside Docker)
**/node_modules/

# Built outputs (rebuilt inside Docker)
**/dist/

# Electron desktop app — not part of any Railway service
electron/

# iOS Xcode project — not part of any Railway service
frontend/ios/

# Capacitor generated assets
frontend/resources/

# Environment / secrets
.env
*.local
tokens.json

# Editor / OS / Git
.DS_Store
.cursor/
*.log
.git/
